{
  "version": 2,
  "installCommand": "corepack enable pnpm && corepack use pnpm@9 && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/fraud-detection build",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api(.*)",
      "dest": "/api$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/artifacts/fraud-detection/dist/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/artifacts/fraud-detection/dist/public/index.html"
    }
  ],
  "public": "artifacts/fraud-detection/dist/public"
}