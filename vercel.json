{
  "version": 2,
  "installCommand": "corepack enable pnpm && corepack use pnpm@9 && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/fraud-detection build && cp -r artifacts/fraud-detection/dist/public/* .",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}